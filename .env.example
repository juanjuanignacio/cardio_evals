# MongoDB Configuration
# =====================
# MongoDB connection settings
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_NAME=RAGQA

# MongoDB URI for RAG scripts
# Format: mongodb://[username:password@]host:port/?directConnection=true
MONGO_URI=mongodb://localhost:27017/?directConnection=true

# Database and collection names for RAG
MONGO_DB_NAME=cardio_refs_2
MONGO_COLLECTION_NAME=abst_refs

# Data Processing Configuration
# ============================
# Path to CSV file with embeddings
CSV_FILE_PATH=cardioRef_embbeding_keywords.csv

# Number of rows to process at once (affects memory usage)
CHUNK_SIZE=5000

# Model Configuration
# ==================
# Model name for RAG system
MODEL_NAME=google/gemma-2-2b-it

# Use GPU for inference (true/false)
USE_GPU=true

# Ollama API Configuration (for evaluation scripts)
# ================================================
# Optional: Ollama API endpoint (if not using default)
# OLLAMA_BASE_URL=http://localhost:11434

# Testing Configuration
# ====================
# Optional: Test query to run after database population
# TEST_QUERY=behaviours of neutrophils

# vLLM Configuration
# ================
# Environment variables for vLLM scripts
VLLM_ENABLE_V1_MULTIPROCESSING=0
VLLM_BATCH_INVARIANT=1
